{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "GR"
        }
      ],
      "destination": "/el/",
      "permanent": false
    },
    {
      "source": "/index.html",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "GR"
        }
      ],
      "destination": "/el/",
      "permanent": false
    }
  ]
}
